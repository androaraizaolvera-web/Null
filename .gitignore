-- Roblox LuaU path highlighter
-- Put this in a LocalScript if you only want yourself to see it.
-- Put this in a Script if you want the server to create the highlights for everyone.

local TARGETS = {
	{
		name = "Tripmine",
		path = { "Workspace", "Lobby", "oh the trips we mine", "Tripmine" },
		fillColor = Color3.fromRGB(255, 80, 80),
		outlineColor = Color3.fromRGB(255, 255, 255),
	},

	-- Add more paths here.
	-- Example:
	-- {
	-- 	name = "MyPart",
	-- 	path = { "Workspace", "FolderName", "PartName" },
	-- 	fillColor = Color3.fromRGB(80, 160, 255),
	-- 	outlineColor = Color3.fromRGB(255, 255, 255),
	-- },
}

local HIGHLIGHT_FOLDER_NAME = "_NullPathHighlights"

local function getHighlightFolder()
	local folder = game:FindFirstChild(HIGHLIGHT_FOLDER_NAME)

	if not folder then
		folder = Instance.new("Folder")
		folder.Name = HIGHLIGHT_FOLDER_NAME
		folder.Parent = game
	end

	return folder
end

local function buildPathText(pathParts, lastIndex)
	local text = "game"

	for index = 1, lastIndex or #pathParts do
		local part = pathParts[index]

		if part:match("^[%a_][%w_]*$") then
			text ..= "." .. part
		else
			text ..= "[\"" .. part .. "\"]"
		end
	end

	return text
end

local function findPath(pathParts)
	local current = game

	for index, childName in ipairs(pathParts) do
		local child = current:FindFirstChild(childName)

		if not child then
			return nil, {
				missingName = childName,
				missingAt = buildPathText(pathParts, index - 1),
				fullPath = buildPathText(pathParts),
			}
		end

		current = child
	end

	return current, nil
end

local function getVisibleAdornee(instance)
	if instance:IsA("BasePart") or instance:IsA("Model") then
		return instance
	end

	local model = instance:FindFirstAncestorWhichIsA("Model")
	if model then
		return model
	end

	local part = instance:FindFirstAncestorWhichIsA("BasePart")
	if part then
		return part
	end

	return nil
end

local function createHighlight(targetConfig, instance)
	local adornee = getVisibleAdornee(instance)

	if not adornee then
		warn(("[Null Highlighter] Found %s, but it has no visible part/model to highlight."):format(targetConfig.name))
		return
	end

	local highlight = Instance.new("Highlight")
	highlight.Name = targetConfig.name .. "_Highlight"
	highlight.Adornee = adornee
	highlight.FillColor = targetConfig.fillColor
	highlight.FillTransparency = 0.45
	highlight.OutlineColor = targetConfig.outlineColor
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = getHighlightFolder()

	print(("[Null Highlighter] Highlighting %s at %s"):format(targetConfig.name, instance:GetFullName()))
end

for _, targetConfig in ipairs(TARGETS) do
	local instance, pathError = findPath(targetConfig.path)

	if instance then
		createHighlight(targetConfig, instance)
	else
		warn(
			("[Null Highlighter] Could not find %s. Missing %q under %s. Full target: %s"):format(
				targetConfig.name,
				pathError.missingName,
				pathError.missingAt,
				pathError.fullPath
			)
		)
	end
end
